# Resend (https://resend.com) — powers the lead capture form's email notification
RESEND_API_KEY=
# Where lead submissions should be emailed
RESEND_EMAIL=

# Vercel Postgres — optional backup so a lead submission is never lost even
# if the email fails to send. Auto-populated when you create a Postgres
# database in the Vercel dashboard and connect it to this project.
POSTGRES_URL=

# Vapi (https://vapi.ai) — powers the "Amara" voice demo at /cinnamon-demo.
# This is the PUBLIC key — safe to expose client-side. Never put the
# private key here.
NEXT_PUBLIC_VAPI_KEY=
